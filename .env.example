# =============================================================================
# Element Shooter — External Dependencies & Environment Requirements
# =============================================================================
# This file documents all external dependencies, browser requirements, and
# dev tooling versions. There are no runtime environment variables; this file
# serves as reference documentation for developers and automated tooling.
# =============================================================================

# -----------------------------------------------------------------------------
# CDN Dependencies (loaded in index.html via <script> tags)
# -----------------------------------------------------------------------------
# All CDN dependencies use exact version pins with Subresource Integrity (SRI)
# hashes to prevent supply-chain attacks. Versions must be manually updated
# in index.html when upgrading.

# Matter.js — 2D physics engine
# Version-pinned: 0.20.0
# CDN URL: https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.20.0/matter.min.js
# SRI hash (sha384): sha384-ZRKYEXtLBVeqs9z1WxyeKutCqnkqolS/r1EUWuoUpG4ZKbnRAIXnHhHdnNuiB6CL
# crossorigin: anonymous
MATTERJS_CDN_URL=https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.20.0/matter.min.js
MATTERJS_VERSION=0.20.0
MATTERJS_SRI_HASH=sha384-ZRKYEXtLBVeqs9z1WxyeKutCqnkqolS/r1EUWuoUpG4ZKbnRAIXnHhHdnNuiB6CL

# Google Fonts — Typography
# Fonts: Michroma (display), Outfit (UI body, weights 300-700), JetBrains Mono (monospace, weights 400-700)
# Loaded via: https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Michroma&family=Outfit:wght@300;400;500;600;700&display=swap
GOOGLE_FONTS_URL=https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Michroma&family=Outfit:wght@300;400;500;600;700&display=swap
GOOGLE_FONTS_PRECONNECT=https://fonts.googleapis.com
GOOGLE_FONTS_GSTATIC_PRECONNECT=https://fonts.gstatic.com

# -----------------------------------------------------------------------------
# Browser Requirements
# -----------------------------------------------------------------------------
# This game runs entirely in the browser as static files. No server-side
# runtime or build step is required. The following browser APIs are required:

# Canvas 2D API — Used for all rendering (game arena, entities, effects, UI)
# https://developer.mozilla.org/en-US/docs/Web/API/CanvasRenderingContext2D
REQUIRES_CANVAS_2D=true

# Web Audio API — Used for synthesized sound effects (oscillator-based audio)
# https://developer.mozilla.org/en-US/docs/Web/API/Web_Audio_API
REQUIRES_WEB_AUDIO_API=true

# localStorage — Used for persisting game settings and adventure mode progress
# https://developer.mozilla.org/en-US/docs/Web/API/Web_Storage_API
REQUIRES_LOCALSTORAGE=true

# requestAnimationFrame — Used for the main game loop (frame-rate independent)
# https://developer.mozilla.org/en-US/docs/Web/API/window/requestAnimationFrame
REQUIRES_REQUESTANIMATIONFRAME=true

# -----------------------------------------------------------------------------
# Dev Tooling (Node.js)
# -----------------------------------------------------------------------------
# Node.js is required ONLY for local development tooling (lint, format, test).
# The game itself has no Node.js dependency.

# Minimum Node.js version required for dev dependencies:
# - ESLint 9.x requires Node.js >= 18.18.0
# - Vitest 3.x requires Node.js >= 18.0.0
# - Husky 9.x requires Node.js >= 18.0.0
NODE_VERSION_REQUIRED=>=18.0.0

# Dev dependencies are listed in package.json with exact version pins (no ^ or ~).
# Install with: npm install
# Key commands:
#   npm run lint          — ESLint check
#   npm run lint:fix      — ESLint auto-fix
#   npm run format        — Prettier format in-place
#   npm run format:check  — Prettier check (no changes)
#   npm test              — Vitest unit tests

# -----------------------------------------------------------------------------
# Dependency Pinning Approach
# -----------------------------------------------------------------------------
# This project uses two layers of dependency pinning:
#
# 1. CDN dependencies (index.html):
#    - Exact version in URL path (e.g., matter-js/0.20.0/)
#    - SRI (Subresource Integrity) hash via integrity attribute (sha384)
#    - crossorigin="anonymous" for CORS-enabled SRI validation
#    - To upgrade: change version in URL, update SRI hash from cdnjs
#
# 2. npm dev dependencies (package.json):
#    - Exact semver pins only (e.g., "9.39.4" not "^9.39.4")
#    - No ranges (^, ~, >=, *)
#    - lockfile (package-lock.json) ensures reproducible installs
